    <worksheet name='Churn Reasons Analysis'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000'>Churn Reason Analysis</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Telecom Data (Telecom Data)' name='federated.0j3wezb0hmrh7d12n4ria0b9jnyi' />
          </datasources>
          <datasource-dependencies datasource='federated.0j3wezb0hmrh7d12n4ria0b9jnyi'>
            <column caption='Top 3 Churn Reasons' datatype='string' name='[Calculation_175992280588296192]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Churn Reason] = &quot;Competitor made better offer&quot;&#10;   OR [Churn Reason] = &quot;Competitor had better devices&quot;&#10;   OR [Churn Reason] = &quot;Attitude of support person&quot;&#10;THEN &quot;Top 3&quot;&#10;ELSE &quot;Other&quot;&#10;END' />
            </column>
            <column datatype='string' name='[Churn Label]' role='dimension' type='nominal' />
            <column datatype='string' name='[Churn Reason]' role='dimension' type='nominal' />
            <column caption='Number of Customers ' datatype='integer' name='[Number of Customers in Group]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_175992280588296192]' derivation='None' name='[none:Calculation_175992280588296192:nk]' pivot='key' type='nominal' />
            <column-instance column='[Churn Label]' derivation='None' name='[none:Churn Label:nk]' pivot='key' type='nominal' />
            <column-instance column='[Churn Reason]' derivation='None' name='[none:Churn Reason:nk]' pivot='key' type='nominal' />
            <column-instance column='[Number of Customers in Group]' derivation='Sum' name='[pcto:sum:Number of Customers in Group:qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Rows' type='PctTotal' />
            </column-instance>
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0j3wezb0hmrh7d12n4ria0b9jnyi].[none:Churn Label:nk]'>
            <groupfilter function='member' level='[none:Churn Label:nk]' member='&quot;Yes&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <manual-sort column='[federated.0j3wezb0hmrh7d12n4ria0b9jnyi].[none:Churn Reason:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;Competitor had better devices&quot;</bucket>
              <bucket>&quot;Attitude of support person&quot;</bucket>
              <bucket>&quot;Competitor made better offer&quot;</bucket>
              <bucket>&quot;Service dissatisfaction&quot;</bucket>
              <bucket>&quot;Price too high&quot;</bucket>
              <bucket>&quot;Long distance charges&quot;</bucket>
              <bucket>&quot;Don&apos;t know&quot;</bucket>
              <bucket>&quot;Moved&quot;</bucket>
              <bucket>&quot;Product dissatisfaction&quot;</bucket>
              <bucket>&quot;Extra data charges&quot;</bucket>
              <bucket>&quot;Attitude of service provider&quot;</bucket>
